generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "pulse"]
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  PENDING_SETUP

  @@schema("public")
}

enum UserRole {
  OWNER
  ADMIN
  OPERATOR
  VIEWER

  @@schema("public")
}

enum PlatformRole {
  PLATFORM_ADMIN
  SUPER_ADMIN
  ADMIN
  TESTER

  @@schema("public")
}

enum AgentStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED

  @@schema("public")
}

enum AgentGoal {
  SALES
  LEAD_QUALIFICATION
  SUPPORT
  BOOKING
  AUTOMATION

  @@schema("public")
}

enum ConversationStatus {
  ACTIVE
  CLOSED
  ESCALATED

  @@schema("public")
}

enum ChannelType {
  WHATSAPP
  TELEGRAM
  DISCORD

  @@schema("public")
}

enum ChannelStatus {
  ACTIVE
  DISCONNECTED
  NEEDS_ATTENTION

  @@schema("public")
}

enum MessageDirection {
  INBOUND
  OUTBOUND
  SYSTEM

  @@schema("public")
}

enum MessageAuthorType {
  CONTACT
  AGENT
  HUMAN
  SYSTEM

  @@schema("public")
}

enum BillingStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE

  @@schema("public")
}

enum BillingPlanStatus {
  DRAFT
  ACTIVE
  DISABLED

  @@schema("public")
}

enum ModulePurchaseStatus {
  ACTIVE
  CANCELED
  EXPIRED

  @@schema("public")
}

enum UsageMetricType {
  AI_CALL
  AUDIO_TRANSCRIPTION
  WORKFLOW_RUN
  STORAGE
  MESSAGE
  AUTOMATION_EXECUTION

  @@schema("public")
}

enum UsageStripeReportStatus {
  SENT
  FAILED
  SKIPPED

  @@schema("public")
}

enum StripeWebhookEventStatus {
  PROCESSED
  IGNORED
  FAILED

  @@schema("public")
}

enum ModuleCatalogStatus {
  DRAFT
  PUBLIC
  PRIVATE
  DISABLED

  @@schema("public")
}

enum TenantModuleStatus {
  ENABLED
  DISABLED

  @@schema("public")
}

enum ModuleTier {
  FREE
  LIGHT
  PRO
  PREMIUM

  @@schema("public")
}

enum ModuleVisibility {
  PUBLIC
  PRIVATE
  HIDDEN

  @@schema("public")
}

enum ModuleRolloutState {
  DRAFT
  PILOT
  GA
  DEPRECATED

  @@schema("public")
}

enum PulseChannelProvider {
  WHATSAPP
  TELEGRAM

  @@schema("pulse")
}

enum PulseChannelStatus {
  ACTIVE
  DISCONNECTED
  NEEDS_ATTENTION
  DISABLED

  @@schema("pulse")
}

enum PulseConversationState {
  NEW
  IN_FLOW
  WAITING_CUSTOMER
  WAITING_OPERATOR
  RESOLVED
  CANCELLED

  @@schema("pulse")
}

enum PulseOperationalStatus {
  ACTIVE
  NEEDS_REVIEW
  ESCALATED
  CLOSED

  @@schema("pulse")
}

enum PulseTicketType {
  SUPPORT
  SALES
  SCHEDULING
  MARKETING
  OPERATOR_REVIEW
  KNOWLEDGE_REQUEST

  @@schema("pulse")
}

enum PulseTicketStatus {
  OPEN
  PENDING_REVIEW
  WAITING_CUSTOMER
  RESOLVED
  CANCELLED

  @@schema("pulse")
}

enum PulseActorType {
  SYSTEM
  USER
  CUSTOMER
  AI
  INTEGRATION

  @@schema("pulse")
}

enum PulsePlaybookStatus {
  DRAFT
  ACTIVE
  ARCHIVED

  @@schema("pulse")
}

enum PulseKnowledgeContextType {
  FAQ
  BUSINESS_DESCRIPTION
  OPERATIONAL_INSTRUCTION
  PRODUCT_SERVICE
  CAMPAIGN_PROMOTION

  @@schema("pulse")
}

enum PulseKnowledgeContextStatus {
  ACTIVE
  ARCHIVED

  @@schema("pulse")
}

enum PulseSkillType {
  SCHEDULER
  SALES
  SUPPORT
  KNOWLEDGE
  MARKETING
  OPERATOR

  @@schema("pulse")
}

enum PulseSkillStatus {
  ACTIVE
  DISABLED

  @@schema("pulse")
}

enum PulseActionExecutionStatus {
  STARTED
  SUCCEEDED
  FAILED

  @@schema("pulse")
}

enum IntegrationProvider {
  GOOGLE_CALENDAR
  OUTLOOK_CALENDAR
  CALENDLY

  @@schema("pulse")
}

enum IntegrationStatus {
  ACTIVE
  DISCONNECTED
  NEEDS_ATTENTION
  DISABLED

  @@schema("pulse")
}

enum ExecutionStatus {
  REQUESTED
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  TIMED_OUT

  @@schema("public")
}

enum TenantContextProfileStatus {
  PENDING
  IN_PROGRESS
  AWAITING_VALIDATION
  APPROVED
  REJECTED

  @@schema("public")
}

enum TenantContextQuestionMode {
  LLM
  MANUAL_FORM

  @@schema("public")
}

enum TenantContextSummaryStatus {
  GENERATED
  APPROVED
  REJECTED

  @@schema("public")
}

model Tenant {
  id                        String                        @id @default(cuid())
  name                      String
  slug                      String                        @unique
  status                    TenantStatus                  @default(PENDING_SETUP)
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  users                     UserMembership[]
  agents                    Agent[]
  conversations             Conversation[]
  messages                  Message[]
  channels                  ChannelAccount[]
  knowledgeItems            KnowledgeItem[]
  billingAccount            BillingAccount?
  pulseEntries              PulseEntry[]
  pulseChannels             PulseChannel[]
  pulseConversations        PulseConversation[]
  pulseTickets              PulseTicket[]
  pulseOperationalEvents    PulseOperationalEvent[]
  pulseActionExecutions     PulseActionExecution[]
  pulsePlaybooks            PulsePlaybook[]
  pulseOperationalSchedules PulseOperationalSchedule[]
  pulseKnowledgeContexts    PulseKnowledgeContext[]
  pulseSkills               PulseSkill[]
  integrationSettings       IntegrationSetting[]
  executionRequests         ExecutionRequest[]
  auditEvents               AuditEvent[]
  moduleInstallations       TenantModuleInstallation[]
  modulePurchases           ModulePurchase[]
  usageEvents               UsageEvent[]
  usageAggregates           UsagePeriodAggregate[]
  usageStripeReports        UsageStripeReport[]
  contextProfiles           TenantContextProfile[]
  contextDrafts             TenantContextDraft[]
  contextAnswers            TenantContextAnswer[]
  contextSummaries          TenantContextSummary[]
  contextVersions           TenantContextProfileVersion[]

  @@index([status])
  @@schema("public")
}

enum AuditStatus {
  SUCCESS
  FAILURE

  @@schema("public")
}

/// Append-only ledger for security-relevant events. Never updated after
/// insert. Tenant-scoped where possible; null tenant for events that
/// happen before a session is established (e.g. failed login from an
/// unknown email).
model AuditEvent {
  id           String      @id @default(cuid())
  tenantId     String?
  actorUserId  String?
  action       String
  resourceType String?
  resourceId   String?
  status       AuditStatus @default(SUCCESS)
  ipAddress    String?
  userAgent    String?
  requestId    String?
  metadata     Json?
  createdAt    DateTime    @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, action, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@schema("public")
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  name           String
  passwordHash   String
  platformRole   PlatformRole?
  platformScopes Json             @default("{}")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  memberships    UserMembership[]
  ownedMessages  Message[]        @relation("HumanMessageAuthor")

  @@index([platformRole])
  @@schema("public")
}

model UserMembership {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      UserRole @default(OPERATOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId, role])
  @@index([tenantId, userId, role])
  @@schema("public")
}

model Agent {
  id              String           @id @default(cuid())
  tenantId        String
  name            String
  status          AgentStatus      @default(DRAFT)
  goal            AgentGoal
  personality     String
  instructions    String
  rules           String[]
  modelProvider   String           @default("openai")
  modelName       String           @default("gpt-4.1-mini")
  temperature     Float            @default(0.3)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations   Conversation[]
  knowledgeItems  KnowledgeItem[]
  channelAccounts ChannelAccount[]

  @@index([tenantId, status])
  @@index([tenantId, goal])
  @@schema("public")
}

model Conversation {
  id                 String             @id @default(cuid())
  tenantId           String
  agentId            String?
  channelAccountId   String
  status             ConversationStatus @default(ACTIVE)
  externalContactId  String
  contactDisplayName String?
  extractedData      Json               @default("{}")
  lastMessageAt      DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent              Agent?             @relation(fields: [agentId], references: [id], onDelete: SetNull)
  channelAccount     ChannelAccount     @relation(fields: [channelAccountId], references: [id], onDelete: Cascade)
  messages           Message[]

  @@unique([tenantId, channelAccountId, externalContactId])
  @@index([tenantId, status, lastMessageAt])
  @@index([tenantId, agentId])
  @@schema("public")
}

model Message {
  id                String            @id @default(cuid())
  tenantId          String
  conversationId    String
  externalMessageId String?
  direction         MessageDirection
  authorType        MessageAuthorType
  humanAuthorId     String?
  content           String
  normalizedPayload Json              @default("{}")
  providerPayload   Json              @default("{}")
  metadata          Json              @default("{}")
  createdAt         DateTime          @default(now())
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation      Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  humanAuthor       User?             @relation("HumanMessageAuthor", fields: [humanAuthorId], references: [id], onDelete: SetNull)

  @@unique([tenantId, conversationId, externalMessageId])
  @@index([tenantId, conversationId, createdAt])
  @@index([tenantId, direction])
  @@schema("public")
}

model ChannelAccount {
  id             String         @id @default(cuid())
  tenantId       String
  agentId        String?
  type           ChannelType
  status         ChannelStatus  @default(DISCONNECTED)
  displayName    String
  externalId     String?
  credentialsRef String?
  settings       Json           @default("{}")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent          Agent?         @relation(fields: [agentId], references: [id], onDelete: SetNull)
  conversations  Conversation[]

  @@unique([tenantId, type, externalId])
  @@index([tenantId, type, status])
  @@index([tenantId, agentId])
  @@schema("public")
}

model KnowledgeItem {
  id        String   @id @default(cuid())
  tenantId  String
  agentId   String?
  title     String
  content   String
  sourceUrl String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([tenantId, agentId])
  @@index([tenantId, updatedAt])
  @@schema("public")
}

model BillingAccount {
  id                   String        @id @default(cuid())
  tenantId             String        @unique
  stripeCustomerId     String?       @unique
  stripeSubscriptionId String?       @unique
  status               BillingStatus @default(INCOMPLETE)
  planKey              String        @default("light")
  currentPeriodEnd     DateTime?
  entitlements         Json          @default("{}")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  tenant               Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  plan BillingPlan @relation(fields: [planKey], references: [key], onDelete: Restrict)

  @@index([planKey, status])
  @@schema("public")
}

model BillingPlan {
  id                    String            @id @default(cuid())
  key                   String            @unique
  displayName           String
  status                BillingPlanStatus @default(DRAFT)
  commercialFeatureFlag String?
  requiredPublicModules Int               @default(0)
  entitlements          Json              @default("{}")
  metadata              Json              @default("{}")
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  billingAccounts    BillingAccount[]
  moduleEntitlements BillingPlanModuleEntitlement[]

  @@index([status, displayName])
  @@map("billing_plans")
  @@schema("public")
}

model BillingPlanModuleEntitlement {
  id        String   @id @default(cuid())
  planId    String
  moduleId  String
  included  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan   BillingPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  module ModuleCatalogItem @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([planId, moduleId])
  @@index([moduleId, included])
  @@map("billing_plan_module_entitlements")
  @@schema("public")
}

model BillingFeatureFlag {
  id        String   @id @default(cuid())
  key       String   @unique
  enabled   Boolean  @default(false)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled, key])
  @@map("billing_feature_flags")
  @@schema("public")
}

model StripeWebhookEvent {
  id            String                   @id @default(cuid())
  stripeEventId String                   @unique
  eventType     String
  status        StripeWebhookEventStatus
  errorMessage  String?
  payload       Json
  receivedAt    DateTime                 @default(now())
  processedAt   DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@index([eventType, receivedAt])
  @@index([status, receivedAt])
  @@map("stripe_webhook_events")
  @@schema("public")
}

model ModulePurchase {
  id                   String               @id @default(cuid())
  tenantId             String
  moduleId             String
  status               ModulePurchaseStatus @default(ACTIVE)
  stripeSubscriptionId String?
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module ModuleCatalogItem @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId])
  @@index([tenantId, status])
  @@index([moduleId, status])
  @@map("module_purchases")
  @@schema("public")
}

model ModuleCatalogItem {
  id           String              @id @default(cuid())
  slug         String              @unique
  displayName  String
  version      String
  description  String
  status       ModuleCatalogStatus @default(DRAFT)
  tier         ModuleTier          @default(FREE)
  visibility   ModuleVisibility    @default(PRIVATE)
  rolloutState ModuleRolloutState  @default(DRAFT)
  featureFlag  String?
  active       Boolean             @default(false)
  storeVisible Boolean             @default(true)
  permissions  Json                @default("[]")
  actions      Json                @default("[]")
  events       Json                @default("[]")
  metadata     Json                @default("{}")
  registeredAt DateTime            @default(now())
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  installations    TenantModuleInstallation[]
  planEntitlements BillingPlanModuleEntitlement[]
  purchases        ModulePurchase[]

  @@index([status, displayName])
  @@index([tier, visibility, rolloutState])
  @@index([active, visibility])
  @@index([storeVisible, active, visibility])
  @@map("module_catalog_items")
  @@schema("public")
}

model TenantModuleInstallation {
  id         String             @id @default(cuid())
  tenantId   String
  moduleId   String
  status     TenantModuleStatus @default(DISABLED)
  config     Json               @default("{}")
  enabledAt  DateTime?
  disabledAt DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module ModuleCatalogItem @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId])
  @@index([tenantId, status])
  @@index([moduleId, status])
  @@map("tenant_module_installations")
  @@schema("public")
}

model UsageEvent {
  id             String          @id @default(cuid())
  tenantId       String
  moduleSlug     String?
  metricType     UsageMetricType
  quantity       Decimal         @db.Decimal(18, 6)
  unit           String
  resourceType   String?
  resourceId     String?
  idempotencyKey String?
  billingPeriod  String
  metadata       Json            @default("{}")
  occurredAt     DateTime        @default(now())
  createdAt      DateTime        @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, billingPeriod, metricType])
  @@index([tenantId, billingPeriod, moduleSlug, metricType, unit])
  @@index([tenantId, moduleSlug, occurredAt])
  @@index([tenantId, resourceType, resourceId])
  @@map("usage_events")
  @@schema("public")
}

model UsageRate {
  id             String          @id @default(cuid())
  metricType     UsageMetricType
  unit           String
  unitPriceCents Decimal         @db.Decimal(18, 6)
  currency       String          @default("usd")
  active         Boolean         @default(false)
  metadata       Json            @default("{}")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([metricType, unit, currency])
  @@index([active, metricType])
  @@map("usage_rates")
  @@schema("public")
}

model UsageStripeMeter {
  id              String          @id @default(cuid())
  metricType      UsageMetricType
  unit            String
  currency        String          @default("usd")
  stripeEventName String
  valueMultiplier Decimal         @default(1) @db.Decimal(18, 6)
  active          Boolean         @default(false)
  metadata        Json            @default("{}")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([metricType, unit, currency])
  @@index([active, metricType])
  @@map("usage_stripe_meters")
  @@schema("public")
}

model UsagePeriodAggregate {
  id             String          @id @default(cuid())
  tenantId       String
  billingPeriod  String
  metricType     UsageMetricType
  unit           String
  quantity       Decimal         @db.Decimal(18, 6)
  events         Int
  currency       String          @default("usd")
  unitPriceCents Decimal?        @db.Decimal(18, 6)
  amountCents    Decimal?        @db.Decimal(18, 6)
  rated          Boolean         @default(false)
  calculatedAt   DateTime        @default(now())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stripeReports UsageStripeReport[]

  @@unique([tenantId, billingPeriod, metricType, unit, currency])
  @@index([tenantId, billingPeriod])
  @@index([tenantId, billingPeriod, rated])
  @@map("usage_period_aggregates")
  @@schema("public")
}

model UsageStripeReport {
  id               String                  @id @default(cuid())
  tenantId         String
  aggregateId      String
  status           UsageStripeReportStatus
  stripeEventName  String?
  stripeIdentifier String?
  stripeCustomerId String?
  value            Int?
  errorMessage     String?
  reportedAt       DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aggregate UsagePeriodAggregate @relation(fields: [aggregateId], references: [id], onDelete: Cascade)

  @@unique([aggregateId])
  @@unique([stripeIdentifier])
  @@index([tenantId, status, createdAt])
  @@map("usage_stripe_reports")
  @@schema("public")
}

enum PulseStatus {
  PROCESSING
  PENDING_VALIDATION
  READY_TO_CONFIRM
  SCHEDULED
  FAILED

  @@schema("pulse")
}

model PulseEntry {
  id             String      @id @default(cuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationId String?
  status         PulseStatus @default(PROCESSING)

  originalMessage String  @default("")
  transcription   String?
  mediaUrl        String?
  contactPhone    String
  contactName     String?

  extractedData Json?
  confidence    Float?
  aiSummary     String?

  scheduledAt    DateTime?
  errorMessage   String?
  retryCount     Int       @default(0)
  processingLogs Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, status, updatedAt])
  @@index([tenantId, contactPhone, createdAt])
  @@map("pulse_entries")
  @@schema("pulse")
}

model PulseChannel {
  id         String               @id @default(cuid())
  tenantId   String
  provider   PulseChannelProvider
  identifier String
  status     PulseChannelStatus   @default(DISCONNECTED)
  limits     Json                 @default("{}")
  metadata   Json                 @default("{}")
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations PulseConversation[]
  events        PulseOperationalEvent[]

  @@unique([tenantId, provider, identifier])
  @@index([tenantId, provider, status])
  @@map("pulse_channels")
  @@schema("pulse")
}

model PulseConversation {
  id                String                 @id @default(cuid())
  tenantId          String
  channelId         String
  participantRef    String
  participantLabel  String?
  state             PulseConversationState @default(NEW)
  operationalStatus PulseOperationalStatus @default(ACTIVE)
  confidence        Float?
  lastActivityAt    DateTime?
  metadata          Json                   @default("{}")
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  tenant  Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel PulseChannel            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  tickets PulseTicket[]
  events  PulseOperationalEvent[]

  @@unique([tenantId, channelId, participantRef])
  @@index([tenantId, operationalStatus, lastActivityAt])
  @@index([tenantId, channelId, lastActivityAt])
  @@index([tenantId, state])
  @@index([tenantId, updatedAt])
  @@map("pulse_conversations")
  @@schema("pulse")
}

model PulseTicket {
  id             String            @id @default(cuid())
  tenantId       String
  conversationId String?
  type           PulseTicketType
  status         PulseTicketStatus @default(OPEN)
  title          String
  summary        String?
  priority       Int               @default(0)
  confidence     Float?
  assignedUserId String?
  metadata       Json              @default("{}")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  resolvedAt     DateTime?

  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation PulseConversation?      @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  events       PulseOperationalEvent[]

  @@index([tenantId, status, updatedAt])
  @@index([tenantId, type, status])
  @@index([tenantId, assignedUserId, status, updatedAt])
  @@index([tenantId, priority, status, updatedAt])
  @@index([tenantId, conversationId, updatedAt])
  @@map("pulse_tickets")
  @@schema("pulse")
}

model PulseOperationalEvent {
  id             String         @id @default(cuid())
  tenantId       String
  eventType      String
  actorType      PulseActorType @default(SYSTEM)
  actorUserId    String?
  channelId      String?
  conversationId String?
  ticketId       String?
  payload        Json           @default("{}")
  metadata       Json           @default("{}")
  occurredAt     DateTime       @default(now())
  createdAt      DateTime       @default(now())

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel      PulseChannel?      @relation(fields: [channelId], references: [id], onDelete: SetNull)
  conversation PulseConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  ticket       PulseTicket?       @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([tenantId, occurredAt])
  @@index([tenantId, eventType, occurredAt])
  @@index([tenantId, conversationId, occurredAt])
  @@index([tenantId, ticketId, occurredAt])
  @@index([tenantId, actorUserId, occurredAt])
  @@map("pulse_operational_events")
  @@schema("pulse")
}

model PulseActionExecution {
  id             String                     @id @default(cuid())
  tenantId       String
  action         String
  idempotencyKey String
  ticketId       String?
  conversationId String?
  status         PulseActionExecutionStatus @default(STARTED)
  attempts       Int                        @default(1)
  metadata       Json                       @default("{}")
  errorMessage   String?
  startedAt      DateTime                   @default(now())
  completedAt    DateTime?
  failedAt       DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, status, updatedAt])
  @@index([tenantId, ticketId, updatedAt])
  @@index([tenantId, conversationId, updatedAt])
  @@index([tenantId, action, status])
  @@index([tenantId, status, action, updatedAt])
  @@map("pulse_action_executions")
  @@schema("pulse")
}

model PulsePlaybook {
  id        String              @id @default(cuid())
  tenantId  String
  key       String
  name      String
  status    PulsePlaybookStatus @default(DRAFT)
  skill     PulseSkillType?
  flow      Json                @default("{}")
  metadata  Json                @default("{}")
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId, status, skill])
  @@map("pulse_playbooks")
  @@schema("pulse")
}

model PulseOperationalSchedule {
  id                String    @id @default(cuid())
  tenantId          String
  timezone          String    @default("UTC")
  businessHours     Json      @default("{}")
  temporaryClosures Json      @default("[]")
  holidayOverrides  Json      @default("[]")
  vacationPeriods   Json      @default("[]")
  operationalPause  Boolean   @default(false)
  pauseReason       String?
  closedMessage     String?
  nextOpeningAt     DateTime?
  metadata          Json      @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId])
  @@index([tenantId, operationalPause, nextOpeningAt])
  @@map("pulse_operational_schedules")
  @@schema("pulse")
}

model PulseKnowledgeContext {
  id        String                      @id @default(cuid())
  tenantId  String
  type      PulseKnowledgeContextType
  title     String
  content   String
  status    PulseKnowledgeContextStatus @default(ACTIVE)
  metadata  Json                        @default("{}")
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, type, status])
  @@index([tenantId, updatedAt])
  @@map("pulse_knowledge_contexts")
  @@schema("pulse")
}

model PulseSkill {
  id        String           @id @default(cuid())
  tenantId  String
  type      PulseSkillType
  status    PulseSkillStatus @default(ACTIVE)
  config    Json             @default("{}")
  metadata  Json             @default("{}")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type])
  @@index([tenantId, status])
  @@map("pulse_skills")
  @@schema("pulse")
}

model IntegrationSetting {
  id             String              @id @default(cuid())
  tenantId       String
  provider       IntegrationProvider
  status         IntegrationStatus   @default(DISCONNECTED)
  displayName    String
  externalRef    String?
  settings       Json                @default("{}")
  credentialsRef String?
  metadata       Json                @default("{}")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider, externalRef])
  @@index([tenantId, provider, status])
  @@index([tenantId, status, updatedAt])
  @@map("integration_settings")
  @@schema("pulse")
}

model ExecutionRequest {
  id             String          @id @default(cuid())
  tenantId       String
  moduleSlug     String
  requestType    String
  status         ExecutionStatus @default(REQUESTED)
  idempotencyKey String?
  context        Json            @default("{}")
  input          Json            @default("{}")
  output         Json?
  errorMessage   String?
  requestedAt    DateTime        @default(now())
  queuedAt       DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  updatedAt      DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, moduleSlug, status])
  @@index([tenantId, status, updatedAt])
  @@index([tenantId, requestType, requestedAt])
  @@map("execution_requests")
  @@schema("public")
}

model TenantContextProfile {
  id                  String                     @id @default(cuid())
  tenantId            String
  status              TenantContextProfileStatus @default(PENDING)
  schemaVersion       Int                        @default(1)
  activeVersionNumber Int?
  completedAt         DateTime?
  approvedAt          DateTime?
  approvedByUserId    String?
  rejectedAt          DateTime?
  rejectedByUserId    String?
  rejectionReason     String?
  metadata            Json                       @default("{}")
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  tenant    Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  drafts    TenantContextDraft[]
  answers   TenantContextAnswer[]
  summaries TenantContextSummary[]
  versions  TenantContextProfileVersion[]

  @@unique([tenantId])
  @@index([tenantId, status, updatedAt])
  @@map("tenant_context_profiles")
  @@schema("public")
}

model TenantContextProfileVersion {
  id              String   @id @default(cuid())
  tenantId        String
  profileId       String
  versionNumber   Int
  schemaVersion   Int      @default(1)
  contract        Json
  business        Json
  communication   Json
  operational     Json
  metadata        Json     @default("{}")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile   TenantContextProfile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  summaries TenantContextSummary[]

  @@unique([profileId, versionNumber])
  @@index([tenantId, versionNumber])
  @@map("tenant_context_profile_versions")
  @@schema("public")
}

model TenantContextDraft {
  id              String                    @id @default(cuid())
  tenantId        String
  profileId       String
  mode            TenantContextQuestionMode @default(LLM)
  schemaVersion   Int                       @default(1)
  answers         Json                      @default("{}")
  currentQuestion String?
  progress        Json                      @default("{}")
  metadata        Json                      @default("{}")
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  tenant  Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile TenantContextProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId])
  @@index([tenantId, updatedAt])
  @@map("tenant_context_drafts")
  @@schema("public")
}

model TenantContextAnswer {
  id          String                    @id @default(cuid())
  tenantId    String
  profileId   String
  questionKey String
  answer      Json
  normalized  Json?
  mode        TenantContextQuestionMode @default(LLM)
  metadata    Json                      @default("{}")
  actorUserId String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  tenant  Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile TenantContextProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, questionKey])
  @@index([tenantId, profileId, updatedAt])
  @@map("tenant_context_answers")
  @@schema("public")
}

model TenantContextSummary {
  id            String                     @id @default(cuid())
  tenantId      String
  profileId     String
  versionId     String?
  schemaVersion Int                        @default(1)
  summary       Json
  contractDraft Json
  status        TenantContextSummaryStatus @default(GENERATED)
  generatedBy   String                     @default("internal")
  actorUserId   String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  tenant  Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profile TenantContextProfile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  version TenantContextProfileVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)

  @@index([tenantId, profileId, createdAt])
  @@index([profileId, status, createdAt])
  @@map("tenant_context_summaries")
  @@schema("public")
}
