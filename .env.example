# Root environment — shared infrastructure values only.
# Copy to `.env`. Per-app values live in apps/api/.env and apps/web/.env.

# ─── Postgres ────────────────────────────────────────────────────────
POSTGRES_USER=synapse
POSTGRES_PASSWORD=synapse
POSTGRES_DB=synapse

# ─── Host port mappings ──────────────────────────────────────────────
POSTGRES_HOST_PORT=5435
REDIS_HOST_PORT=6380
API_HOST_PORT=5000
WEB_HOST_PORT=5001

# ─── Public API URL ──────────────────────────────────────────────────
# Browser-facing API origin. Baked into the web build at compile time.
PUBLIC_API_BASE_URL=http://localhost:5000/v1
