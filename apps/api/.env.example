# API runtime environment.
# Copy to `apps/api/.env`. Infra values live in the root `.env`.

NODE_ENV=development
PORT=4000

# Local-dev URLs — talk to the dockerized infra via published host ports.
# Compose overrides these for the API container itself.
DATABASE_URL=postgresql://synapse:synapse@localhost:5435/synapse?schema=public
REDIS_URL=redis://localhost:6380

# Auth
JWT_SECRET=replace-with-a-long-random-secret-of-at-least-32-chars
JWT_EXPIRES_IN=1d
JWT_ISSUER=synapse-api
JWT_AUDIENCE=synapse-web

# CORS allowlist for the browser
CORS_ORIGINS=http://localhost:5001,http://127.0.0.1:5001

# OpenAI
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4.1-mini

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Channels
TELEGRAM_BOT_TOKEN=

# First-admin provisioning (`npm run admin:create`)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
ADMIN_TENANT_NAME=
ADMIN_TENANT_SLUG=
